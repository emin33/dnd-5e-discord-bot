# D&D 5e Bot configuration. Copy to .env and edit:  cp .env.example .env
#
# Every key below maps 1:1 to a field on dnd_bot.config.Settings
# (Main/dnd_bot/config.py, matched case-insensitively). Settings rejects
# unknown keys in .env at boot (extra='forbid'), so this file must stay in
# sync with config.py; tests/unit/test_env_example.py enforces that.
# Commented lines show the built-in default; uncomment only what you change.

# --- Discord (required) ---
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# --- Active LLM profile (see config/profiles.yaml) ---
# The default "production" profile uses an Anthropic narrator and a Groq
# brain, so it also needs ANTHROPIC_API_KEY and GROQ_API_KEY below.
# ACTIVE_PROFILE=production

# --- Ollama connection (shared by profiles that use ollama) ---
# OLLAMA_HOST=http://localhost:11434

# --- LLM provider API keys (set the ones your profile uses) ---
# GROQ_API_KEY=
# GROQ_MAX_RETRIES=3
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# ELEVENLABS_API_KEY=
# DEEPGRAM_API_KEY=

# --- LLM tuning ---
# NARRATOR_TEMPERATURE=0.75
# RULES_TEMPERATURE=0.1
# LLM_TIMEOUT=120.0

# --- Database ---
# DATABASE_PATH=data/dnd_bot.db

# --- ChromaDB (vector store) ---
# CHROMA_PERSIST_PATH=data/chroma

# --- SRD data path (relative to Main/) ---
# SRD_DATA_PATH=../5e-database/src/2014

# --- Logging / debug ---
# LOG_LEVEL=INFO
# DEBUG_SHOW_INTENTS=false
# DEBUG_LOG_LLM_OUTPUT=false

# --- Image generation (optional, immersion features) ---
# IMAGE_PROVIDER=fal
# FAL_KEY=
# FAL_MODEL=fal-ai/flux/dev
# OPENAI_IMAGE_API_KEY=
# LOCAL_IMAGE_MODEL=black-forest-labs/FLUX.1-dev
# LOCAL_IMAGE_STEPS=20
# LOCAL_IMAGE_GUIDANCE=3.5

# --- Inworld TTS (narrator voice) ---
# INWORLD_API_KEY=
# INWORLD_TTS_MODEL=inworld-tts-1.5-mini
# INWORLD_TTS_VOICE=Sarah

# --- Fish Speech (local TTS) ---
# FISH_SPEECH_URL=http://localhost:8080
# FISH_SPEECH_INSTANCES=1

# --- Voice / Riva / LiveKit (optional, voice mode only) ---
# NGC_API_KEY=
# RIVA_ASR_URL=localhost:50051
# RIVA_TTS_URL=localhost:50052
# TTS_VOICE=Magpie-Multilingual.EN-US.Aria
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
